generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String            @id @default(cuid())
  clerkId              String            @unique
  email                String            @unique
  name                 String?
  credits              Int               @default(10)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  plan                 String            @default("free")
  planExpiresAt        DateTime?
  resendApiKey         String?
  sendingDomain        String?
  sendingFromEmail     String?
  sendingFromName      String?
  stripeCustomerId     String?
  workspaceName        String?
  businessType         String?
  businessUrl          String?
  googleAdsId          String?
  googleAnalyticsId    String?
  metaPixelId          String?
  onboardingCompleted  Boolean           @default(false)
  tiktokPixelId        String?
  webhookUrl           String?
  amazonTrackingId     String?
  clickbankNickname    String?
  jvzooAffiliateId     String?
  sharesaleAffiliateId String?
  warriorplusId        String?
  affiliateOffers      AffiliateOffer[]
  agencyAudits         AgencyAudit[]
  automations          Automation[]
  automationRuns       AutomationRun[]
  businessProfile      BusinessProfile?
  campaigns            Campaign[]
  clients              Client[]
  consultPackages      ConsultPackage[]
  creatives            CreativeWork[]
  dropshipProducts     DropshipProduct[]
  emailBroadcasts      EmailBroadcast[]
  emailContacts        EmailContact[]
  emailFlows           EmailFlow[]
  leads                Lead[]
  localAudits          LocalAudit[]
  optInForms           OptInForm[]
  products             Product[]
  proposals            Proposal[]
  reports              ReportIntake[]
  servicePackages      ServicePackage[]
  sites                Site[]
}

model OptInForm {
  id          String   @id @default(cuid())
  userId      String
  name        String
  headline    String?
  subheadline String?
  buttonText  String   @default("Subscribe")
  tags        String[] @default([])
  redirectUrl String?
  active      Boolean  @default(true)
  views       Int      @default(0)
  submissions Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

model AnalysisRun {
  id                     String                  @id @default(cuid())
  userId                 String?
  mode                   String
  inputUrl               String
  linkType               String?
  title                  String?
  score                  Int?
  verdict                String?
  confidence             String?
  summary                String?
  rawSignals             Json?
  decisionPacket         Json?
  pinned                 Boolean                 @default(false)
  executionState         Json?
  outcome                Json?
  createdAt              DateTime                @default(now())
  assetPackages          AssetPackage[]
  campaigns              Campaign[]
  opportunityAssessments OpportunityAssessment[]
}

model OpportunityAssessment {
  id                      String         @id @default(cuid())
  analysisRunId           String
  status                  String
  totalScore              Int?
  demandPotential         Int?
  offerStrength           Int?
  emotionalLeverage       Int?
  trustCredibility        Int?
  conversionReadiness     Int?
  adViability             Int?
  emailLifecyclePotential Int?
  seoPotential            Int?
  differentiation         Int?
  risk                    Int?
  topGaps                 Json?
  topStrengths            Json?
  recommendedPath         String?
  opportunityPacket       Json?
  createdAt               DateTime       @default(now())
  assetPackages           AssetPackage[]
  analysisRun             AnalysisRun    @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
}

model AssetPackage {
  id                      String                 @id @default(cuid())
  analysisRunId           String
  opportunityAssessmentId String?
  mode                    String
  adHooks                 Json
  adScripts               Json
  adBriefs                Json?
  landingPage             Json
  emailSequences          Json
  executionChecklist      Json
  createdAt               DateTime               @default(now())
  analysisRun             AnalysisRun            @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
  opportunityAssessment   OpportunityAssessment? @relation(fields: [opportunityAssessmentId], references: [id])
}

model Campaign {
  id             String          @id @default(cuid())
  userId         String?
  name           String
  mode           String
  status         String          @default("draft")
  productName    String?
  productUrl     String?
  analysisRunId  String?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  currentPhase   Int             @default(1)
  sourceType     String?
  sourceUrl      String?
  workflowState  Json?
  adVariations   AdVariation[]
  analysisRun    AnalysisRun?    @relation(fields: [analysisRunId], references: [id])
  user           User?           @relation(fields: [userId], references: [id])
  checklistItems ChecklistItem[]
  creatives      CreativeWork[]
  emailDrafts    EmailDraft[]
  landingDraft   LandingDraft?
}

model CreativeWork {
  id         String    @id @default(cuid())
  name       String
  type       String
  userId     String
  campaignId String?
  state      Json
  outputUrl  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  user       User      @relation(fields: [userId], references: [id])
}

model AdVariation {
  id         String   @id @default(cuid())
  campaignId String
  name       String
  type       String
  content    Json
  platform   String?
  status     String   @default("draft")
  notes      String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  metrics    Json?
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model LandingDraft {
  id          String   @id @default(cuid())
  campaignId  String   @unique
  headline    String?
  subheadline String?
  trustBar    Json?
  bullets     Json?
  socialProof String?
  guarantee   String?
  faqItems    Json?
  ctaCopy     String?
  urgencyLine String?
  status      String   @default("draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model EmailDraft {
  id         String   @id @default(cuid())
  campaignId String
  sequence   String
  position   Int
  subject    String?
  preview    String?
  body       String?
  timing     String?
  status     String   @default("draft")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model ChecklistItem {
  id         String   @id @default(cuid())
  campaignId String
  day        String
  position   Int
  text       String
  done       Boolean  @default(false)
  createdAt  DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model ReportIntake {
  id         String   @id @default(cuid())
  reportType String
  fileUrl    String?
  notes      String?
  createdAt  DateTime @default(now())
  status     String   @default("submitted")
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
}

model EmailFlow {
  id            String   @id @default(cuid())
  userId        String?
  name          String
  trigger       String
  triggerConfig Json?
  status        String   @default("draft")
  nodes         Json     @default("[]")
  edges         Json     @default("[]")
  tags          String[] @default([])
  enrolled      Int      @default(0)
  sent          Int      @default(0)
  opens         Int      @default(0)
  clicks        Int      @default(0)
  conversions   Int      @default(0)
  revenue       Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User?    @relation(fields: [userId], references: [id])
  enrollments   EmailFlowEnrollment[]
}

model EmailFlowEnrollment {
  id            String    @id @default(cuid())
  flowId        String
  contactEmail  String
  userId        String
  status        String    @default("active")  // active | paused | completed | failed
  currentNodeId String?
  resumeAfter   DateTime?
  emailsSent    Int       @default(0)
  errors        Json      @default("[]")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  flow          EmailFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([flowId])
  @@index([status, resumeAfter])
  @@unique([flowId, contactEmail])
}

model EmailContact {
  id         String   @id @default(cuid())
  userId     String?
  email      String
  firstName  String?
  lastName   String?
  tags       String[] @default([])
  properties Json?
  status     String   @default("subscribed")
  source     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User?    @relation(fields: [userId], references: [id])

  @@unique([userId, email])
}

model EmailBroadcast {
  id           String    @id @default(cuid())
  userId       String?
  name         String
  subject      String
  previewText  String?
  body         String
  fromName     String?
  fromEmail    String?
  status       String    @default("draft")
  segmentTags  String[]  @default([])
  scheduledAt  DateTime?
  sentAt       DateTime?
  recipients   Int       @default(0)
  opens        Int       @default(0)
  clicks       Int       @default(0)
  bounces      Int       @default(0)
  unsubscribes Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User?     @relation(fields: [userId], references: [id])
}

model Client {
  id               String           @id @default(cuid())
  userId           String
  name             String
  email            String?
  phone            String?
  company          String?
  website          String?
  niche            String?
  tags             String[]         @default([])
  customFields     Json?
  pipelineStage    String           @default("lead")
  dealValue        Float?
  priority         String           @default("normal")
  healthScore      Int              @default(50)
  healthStatus     String           @default("yellow")
  lastContactAt    DateTime?
  notes            String?
  sourceCampaignId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User             @relation(fields: [userId], references: [id])
  activities       ClientActivity[]

  @@index([userId, pipelineStage])
  @@index([userId, healthScore])
}

model ClientActivity {
  id        String   @id @default(cuid())
  clientId  String
  type      String
  content   String?
  metadata  Json?
  createdBy String?
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Site {
  id           String        @id @default(cuid())
  userId       String
  name         String
  slug         String        @unique
  description  String?
  faviconEmoji String?       @default("🚀")
  theme        Json          @default("{\"font\": \"inter\", \"mode\": \"dark\", \"primaryColor\": \"#06b6d4\"}")
  customDomain String?
  published    Boolean       @default(false)
  totalViews   Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  pages        SitePage[]
  products     SiteProduct[]

  @@index([userId])
}

model SitePage {
  id        String   @id @default(cuid())
  siteId    String
  title     String
  slug      String   @default("home")
  blocks    Json     @default("[]")
  seoTitle  String?
  seoDesc   String?
  published Boolean  @default(true)
  order     Int      @default(0)
  views     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, slug])
  @@index([siteId])
}

model SiteProduct {
  id          String   @id @default(cuid())
  siteId      String
  name        String
  description String?
  price       Int
  compareAt   Int?
  images      String[] @default([])
  slug        String
  inventory   Int?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, slug])
  @@index([siteId])
}

model SiteOrder {
  id              String   @id @default(cuid())
  siteId          String
  productId       String
  customerEmail   String
  customerName    String?
  amountCents     Int
  currency        String   @default("usd")
  status          String   @default("pending")
  stripePaymentId String?
  shippingAddress Json?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([siteId])
  @@index([siteId, status])
}

model ScanResult {
  id          String   @id @default(cuid())
  mode        String
  title       String
  payloadJson Json
  createdAt   DateTime @default(now())
}

model WebhookLog {
  id         String   @id @default(cuid())
  source     String
  workflow   String?
  status     String   @default("received")
  payload    Json
  response   Json?
  error      String?
  durationMs Int?
  createdAt  DateTime @default(now())

  @@index([source, createdAt])
}

model CreditLog {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  balance   Int
  action    String
  detail    String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Lead {
  id             String    @id @default(cuid())
  userId         String
  name           String
  niche          String
  location       String
  website        String?
  phone          String?
  email          String?
  address        String?
  rating         Float?
  reviewCount    Int?
  googlePlaceId  String?
  score          Int?
  verdict        String?
  summary        String?
  audience       String?
  painPoints     String?
  angle          String?
  topGaps        Json?
  topStrengths   Json?
  weaknesses     Json?
  adHooks        Json?
  outreachEmail  Json?
  landingPage    Json?
  status         String    @default("new")
  outreachSentAt DateTime?
  emailOpened    Boolean   @default(false)
  emailReplied   Boolean   @default(false)
  clientId       String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  adsJson        Json?
  analyzerJson   Json?
  emailsJson     Json?
  profileJson    Json?
  websiteJson    Json?
  user           User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, status])
  @@index([userId, niche])
}

model Product {
  id            String   @id @default(cuid())
  userId        String
  name          String
  description   String?
  price         String?
  originalPrice String?
  platform      String
  productUrl    String
  affiliateUrl  String?
  imageUrl      String?
  category      String?
  niche         String?
  commission    String?
  gravity       Float?
  scanData      Json?
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, platform])
  @@index([userId, niche])
}

model ConsultPackage {
  id           String   @id @default(cuid())
  userId       String
  name         String
  type         String
  price        Float
  currency     String   @default("USD")
  billingCycle String   @default("one_time")
  duration     String?
  deliverables Json     @default("[]")
  isHighTicket Boolean  @default(false)
  targetNiche  String?
  active       Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Proposal {
  id               String    @id @default(cuid())
  userId           String
  leadId           String?
  clientId         String?
  title            String
  problemStatement String?
  solution         String?
  socialProof      String?
  guarantee        String?
  urgency          String?
  packages         Json      @default("[]")
  totalValue       Float?
  status           String    @default("draft")
  sentAt           DateTime?
  viewedAt         DateTime?
  respondedAt      DateTime?
  expiresAt        DateTime?
  viewCount        Int       @default(0)
  aiJson           Json?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, status])
}

model ServicePackage {
  id             String   @id @default(cuid())
  userId         String
  name           String
  tier           String
  price          Float
  billingCycle   String   @default("monthly")
  deliverables   Json     @default("[]")
  targetNiche    String?
  targetLocation String?
  active         Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model LocalAudit {
  id              String   @id @default(cuid())
  userId          String
  leadId          String?
  businessName    String
  businessUrl     String?
  niche           String?
  location        String?
  phone           String?
  overallScore    Int?
  gmbScore        Int?
  reviewScore     Int?
  citationScore   Int?
  websiteScore    Int?
  seoScore        Int?
  competitorScore Int?
  auditJson       Json?
  reportJson      Json?
  packagesJson    Json?
  reviewTemplates Json?
  gmbPostsJson    Json?
  keywordsJson    Json?
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, niche])
}

model AffiliateOffer {
  id             String   @id @default(cuid())
  userId         String
  name           String
  platform       String
  niche          String
  url            String
  affiliateUrl   String?
  vendorId       String?
  commission     String?
  recurringComm  String?
  epc            Float?
  gravity        Float?
  convRate       Float?
  refundRate     Float?
  avgOrderValue  Float?
  cookieDuration String?
  offerAnalysis  Json?
  funnelJson     Json?
  trafficAngles  Json?
  swipeJson      Json?
  adHooksJson    Json?
  landingJson    Json?
  keywordsJson   Json?
  competitorJson Json?
  status         String   @default("researching")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, platform])
  @@index([userId, niche])
  @@index([userId, status])
}

model DropshipProduct {
  id               String   @id @default(cuid())
  userId           String
  name             String
  niche            String
  category         String?
  supplierUrl      String?
  supplierName     String?
  supplierPrice    Float?
  shippingCost     Float?
  shippingTime     String?
  moq              Int?
  suggestedPrice   Float?
  suggestedMsrp    Float?
  profitMargin     Float?
  profitPerUnit    Float?
  breakEvenRoas    Float?
  demandScore      Int?
  competitionScore Int?
  trendScore       Int?
  marginScore      Int?
  winnerScore      Int?
  productJson      Json?
  storeJson        Json?
  adAnglesJson     Json?
  emailsJson       Json?
  supplierJson     Json?
  ugcBriefJson     Json?
  status           String   @default("researching")
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, niche])
  @@index([userId, status])
  @@index([userId, winnerScore])
}

model AgencyAudit {
  id              String   @id @default(cuid())
  userId          String
  leadId          String?
  clientId        String?
  businessName    String
  businessUrl     String?
  niche           String
  location        String?
  businessType    String
  overallScore    Int?
  trafficScore    Int?
  conversionScore Int?
  offerScore      Int?
  trustScore      Int?
  automationScore Int?
  auditJson       Json?
  strategyJson    Json?
  proposalJson    Json?
  deliverableJson Json?
  pricingJson     Json?
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, businessType])
}

model BusinessProfile {
  id                 String    @id @default(cuid())
  userId             String    @unique
  businessType       String
  businessName       String?
  niche              String?
  location           String?
  website            String?
  mainOffer          String?
  offerPrice         String?
  offerType          String?
  targetAudience     String?
  audienceAge        String?
  audienceGender     String?
  audiencePains      Json?
  audienceDesires    Json?
  stage              String    @default("starting")
  monthlyRevenue     String?
  mainGoal           String?
  activeSystems      Json      @default("[]")
  systemScore        Int       @default(0)
  setupCompleted     Boolean   @default(false)
  setupStep          Int       @default(0)
  recommendedSystems Json?
  recommendedAt      DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id])
}

model Automation {
  id            String          @id @default(cuid())
  userId        String
  campaignId    String?
  name          String
  description   String?
  trigger       String          @default("manual")
  triggerConfig Json?
  status        String          @default("draft")
  nodes         Json            @default("[]")
  edges         Json            @default("[]")
  runsTotal     Int             @default(0)
  runsSuccess   Int             @default(0)
  runsFailed    Int             @default(0)
  lastRunAt     DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User            @relation(fields: [userId], references: [id])
  runs          AutomationRun[]

  @@index([userId, status])
}

model AutomationRun {
  id            String              @id @default(cuid())
  automationId  String
  userId        String
  status        String              @default("running")
  trigger       String              @default("manual")
  contactsCount Int                 @default(0)
  emailsSent    Int                 @default(0)
  errorCount    Int                 @default(0)
  stoppedAtNode String?
  resumeAfter   DateTime?
  metadata      Json?
  startedAt     DateTime            @default(now())
  completedAt   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  automation    Automation          @relation(fields: [automationId], references: [id], onDelete: Cascade)
  user          User                @relation(fields: [userId], references: [id])
  steps         AutomationRunStep[]

  @@index([automationId])
  @@index([userId])
  @@index([status])
  @@index([resumeAfter, status])
}

model AutomationRunStep {
  id        String        @id @default(cuid())
  runId     String
  nodeId    String
  nodeType  String
  status    String        @default("pending")
  output    Json?
  error     String?
  startedAt DateTime?
  endedAt   DateTime?
  createdAt DateTime      @default(now())
  run       AutomationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([runId, nodeId])
}

// ---------------------------------------------------------------------------
// Himalaya: Templates, Presets, Memory
// ---------------------------------------------------------------------------

model HimalayaSubscription {
  id              String   @id @default(cuid())
  userId          String   @unique
  tier            String   @default("free") // free, pro, business
  runsUsed        Int      @default(0)
  runsLimit       Int      @default(2)
  deploysUsed     Int      @default(0)
  deploysLimit    Int      @default(1)
  executionsUsed  Int      @default(0)
  outcomesLogged  Int      @default(0)
  stripeCustomerId String?
  stripeSubId     String?
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model HimalayaFunnelEvent {
  id        String   @id @default(cuid())
  userId    String?
  sessionId String?
  event     String   // page_view, run_start, run_complete, results_view, upgrade_click, purchase, deploy, execute_start, execute_complete, outcome_submit
  metadata  Json?    // { runId, tier, path, etc }
  createdAt DateTime @default(now())

  @@index([event])
  @@index([userId])
  @@index([createdAt])
}

model HimalayaDeployment {
  id              String   @id @default(cuid())
  userId          String
  analysisRunId   String
  siteId          String?
  campaignId      String?
  emailFlowId     String?
  version         Int      @default(1)
  qaScore         Int?
  qaReport        Json?
  sections        Json?    // snapshot of what was deployed
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([analysisRunId])
}

model HimalayaPipelineLog {
  id              String   @id @default(cuid())
  userId          String
  analysisRunId   String?
  mode            String
  overallStatus   String   // success, partial, fallback, failed
  stages          Json     // PipelineStage[]
  totalDurationMs Int
  savedEntityIds  Json?    // { analysisRunId, assetPackageId, profileId }
  warnings        Json?    // string[]
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([analysisRunId])
}

model HimalayaProfile {
  id              String   @id @default(cuid())
  userId          String
  budget          String
  timeAvailable   String
  skills          Json     // string[]
  riskTolerance   String
  primaryGoal     String
  businessStage   String
  existingUrl     String?
  niche           String?
  description     String?
  recommendedPath String?
  decisionResult  Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model HimalayaTemplate {
  id            String   @id @default(cuid())
  userId        String
  name          String
  assetType     String   // adHooks, adScripts, landingPage, emailSequences, executionChecklist, adBriefs
  mode          String   // operator, consultant
  content       Json
  sourceRunId   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([userId, assetType])
}

model HimalayaPreset {
  id            String   @id @default(cuid())
  userId        String
  name          String
  config        Json     // { tone, density, homepageStyle, emailTone, roadmapDepth, businessType }
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model HimalayaMemory {
  id            String   @id @default(cuid())
  userId        String   @unique
  lastNiche     String?
  lastMode      String?
  lastInputUrl  String?
  lastPresetId  String?
  preferredExport String? // markdown, docx, json
  regenCounts   Json?    // { adHooks: 3, emails: 5, ... }
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model EmailIntegration {
  id           String    @id @default(cuid())
  userId       String    @unique
  provider     String    // gmail, outlook
  email        String
  accessToken  String
  refreshToken String
  expiresAt    DateTime?
  connected    Boolean   @default(true)
  dailyLimit   Int       @default(500)  // Sending limit per day
  sentToday    Int       @default(0)
  lastResetAt  DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
}

model EmailTracking {
  id          String    @id @default(cuid())
  userId      String
  leadId      String?
  messageId   String?   // Provider message ID
  to          String
  subject     String
  body        String    @db.Text
  sent        Boolean   @default(false)
  sentAt      DateTime?
  opened      Boolean   @default(false)
  openedAt    DateTime?
  clicked     Boolean   @default(false)
  clickedAt   DateTime?
  replied     Boolean   @default(false)
  repliedAt   DateTime?
  replyBody   String?   @db.Text
  bounced     Boolean   @default(false)
  error       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([leadId])
  @@index([to])
}
