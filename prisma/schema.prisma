generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Project {
  id        String      @id @default(cuid())
  name      String
  type      ProjectType
  createdAt DateTime    @default(now())
  scans     ScanResult[]
}

model ScanResult {
  id          String   @id @default(cuid())
  mode        ScanMode
  title       String
  payloadJson Json
  createdAt   DateTime @default(now())
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])
}

enum ProjectType {
  product
  business
}

enum ScanMode {
  product
  business
}
